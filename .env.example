# ─── FlowLedger Environment Variables ────────────────────────────────────────
# Copy this file to .env. For local dev (mock Canton) only the first two
# sections are required. Everything else is needed for real Canton integration.

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"
# Production: DATABASE_URL="postgresql://user:pass@localhost:5432/flowledger"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (Magic Link Auth) ──────────────────────────────────────────────────
# Leave blank for local dev — use /api/dev/signin instead.
# Production: Resend, Postmark, SendGrid, or any SMTP provider.
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@flowledger.app"

# ─── Canton Network Environment ───────────────────────────────────────────────
# mock     → MockCantonAdapter, no validator needed (default for local dev)
# localnet → cn-quickstart running locally via Docker, no external credentials
# devnet   → NaaS-hosted validator (Launchnodes, Proof Group, Edgevana)
# testnet  → pre-production testnet (separate NaaS credentials)
# mainnet  → production
CANTON_NETWORK_ENV="mock"

# ─── Canton — LocalNet (cn-quickstart via Docker) ─────────────────────────────
# https://github.com/digital-asset/cn-quickstart
# Run: make setup && make build && make start
# No external credentials needed. Ports are set by cn-quickstart defaults.
#
# CANTON_VALIDATOR_URL="http://localhost:5003"   # Validator App HTTP API
# CANTON_LEDGER_URL="http://localhost:3901"      # Ledger API v2
# CANTON_AUTH_MODE="self-signed"                 # No auth server needed
# CANTON_AUTH_SECRET="localnet-dev-secret"       # Any string for LocalNet
# CANTON_AUTH_AUDIENCE="https://canton.network.global"
# CANTON_AUTH_SUBJECT="ledger-api-user"
# CANTON_PARTY_ID=""                             # From cn-quickstart validator UI

# ─── Canton — DevNet / MainNet (NaaS provider) ────────────────────────────────
# Providers: Launchnodes (canton@launchnodes.com), Proof Group, Edgevana
# They give you all values below. NaaS handles SV sponsorship + IP allowlisting.
#
# CANTON_VALIDATOR_URL=""       # Your validator's Validator App HTTP URL
# CANTON_LEDGER_URL=""          # Your validator's Ledger API URL
# CANTON_AUTH_MODE="client-credentials"
# CANTON_AUTH_TOKEN_URL=""      # OAuth2 token endpoint from your provider
# CANTON_AUTH_CLIENT_ID=""
# CANTON_AUTH_CLIENT_SECRET=""
# CANTON_AUTH_AUDIENCE="https://canton.network.global"
# CANTON_AMULET_PACKAGE_ID=""   # Amulet package ID on the network
# CANTON_PARTY_ID=""            # Your treasury internal party ID

# ─── Featured App — CC Reward Earning ─────────────────────────────────────────
# Required for MainNet reward earning. Apply at canton.foundation/featured-app-request
# within 2 weeks of your MainNet launch. After approval, you receive a FeaturedAppRight
# contract ID. Set it here — startup checks will verify it on boot.
#
# CANTON_APP_PROVIDER_PARTY and CANTON_FEATURED_APP_RIGHT_CONTRACT_ID are set
# after your Featured App application is approved by the Canton Tokenomics Committee.
CANTON_APP_PROVIDER_PARTY=
CANTON_FEATURED_APP_RIGHT_CONTRACT_ID=

# ─── DSO Party ────────────────────────────────────────────────────────────────
# The Canton Network DSO party. Ask your NaaS provider for this value.
# Required for Daml contract deployment (FeaturedApp.daml uses this as observer).
CANTON_DSO_PARTY=

# ─── Scan API ─────────────────────────────────────────────────────────────────
# Public endpoint for reading network stats (TPS, round info).
# Ask your NaaS provider or use the public Canton Scan URL for your network.
# Used by RewardTracker.estimateMonthlyRewards() to calculate projected CC earnings.
CANTON_SCAN_URL=

# ─── WalletUserProxy Template ─────────────────────────────────────────────────
# Template ID from splice-util-featured-app-proxies package.
# Required for proxied transfers that automatically create FeaturedAppActivityMarkers.
# Get this from your NaaS provider after deploying the WalletUserProxy template.
CANTON_WALLET_PROXY_TEMPLATE_ID=

# ─── TestNet — pre-production validation ──────────────────────────────────────
# Use these to validate your integration against testnet before going to MainNet.
# Get from your NaaS provider — separate from DevNet credentials.
CANTON_TESTNET_LEDGER_URL=
CANTON_TESTNET_REGISTRY_URL=
CANTON_TESTNET_AUTH_CLIENT_ID=
CANTON_TESTNET_AUTH_CLIENT_SECRET=

# ─── MainNet — production ─────────────────────────────────────────────────────
# Get these from your NaaS provider (Launchnodes, Proof Group, Edgevana).
# These are separate from DevNet/TestNet credentials.
CANTON_MAINNET_LEDGER_URL=
CANTON_MAINNET_REGISTRY_URL=
CANTON_MAINNET_AUTH_CLIENT_ID=
CANTON_MAINNET_AUTH_CLIENT_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CANTON_NETWORK="mock"

# ─── Operator Console (/admin) ────────────────────────────────────────────────
# Comma-separated list of emails that can access /admin routes (FlowLedger team only)
FLOWLEDGER_ADMIN_EMAILS="admin@flowledger.io"

# ─── Canton Wallet Auth ───────────────────────────────────────────────────────
# Set to "true" on MainNet to require Ed25519 signature verification on wallet sign-in
CANTON_VERIFY_SIGNATURES=

# ─── Daml Package ────────────────────────────────────────────────────────────
# Hash printed by `daml build` after uploading the FlowLedger DAR to your validator
# Without this, Daml contract methods return placeholder IDs (transfers still work)
CANTON_DAML_PACKAGE_ID=

# ─── Cron ────────────────────────────────────────────────────────────────────
# Vercel sets this automatically on cron requests. Set it manually for self-hosted.
CRON_SECRET=
